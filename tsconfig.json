{
  "compilerOptions": {
    "outDir": "build/lib",
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "sourceMap": true,
    "allowJs": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "esModuleInterop": true
  },
  "include": ["./src/**/*"]
}
